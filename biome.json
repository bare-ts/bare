{
  "$schema": "https://biomejs.dev/schemas/1.6.0/schema.json",
  "files": {
    "ignoreUnknown": true
  },
  "formatter": {
    "indentStyle": "space",
    "ignore": ["tests-corpus"]
  },
  "linter": {
    "rules": {
      "all": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": "off",
        "noUselessLoneBlockStatements": "off"
      },
      "nursery": {
        "all": true,
        "noConsole": "off",
        "noNamespaceImport": "off",
        "noBarrelFile": "off",
        "noNodejsModules": "off",
        "noReExportAll": "off",
        "noUndeclaredDependencies": "off",
        "useNodeAssertStrict": "off",
        "useImportRestrictions": "off"
      },
      "style": {
        "useForOf": "off",
        "useImportType": "off",
        "useNamingConvention": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "indentWidth": 4,
      "semicolons": "asNeeded"
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  }
}
